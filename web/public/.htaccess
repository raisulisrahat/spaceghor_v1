Options -MultiViews
RewriteEngine On
RewriteBase /

# ------------------------------------------------------------------
# Social Media Crawler → Django SEO Proxy
# When Facebook/WhatsApp/Telegram etc. crawl a product or blog URL,
# redirect them to the Django backend which renders server-side HTML
# with the correct og:title, og:description, og:image for that page.
# ------------------------------------------------------------------

RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|Facebot|Twitterbot|WhatsApp|TelegramBot|Discordbot|Slackbot|LinkedInBot|googlebot|bingbot|rogerbot|DuckDuckBot|ia_archiver) [NC]
RewriteCond %{REQUEST_URI} ^/(product|blog|offer|step)/ [NC]
RewriteRule ^(.*)$ https://api.spaceghor.com/api/seo-proxy/?path=/$1 [L,R=302]

# ------------------------------------------------------------------
# Redirect sitemap.xml to Django backend dynamic sitemap
# ------------------------------------------------------------------
RewriteRule ^sitemap\.xml$ https://api.spaceghor.com/sitemap.xml [L,R=302]

# ------------------------------------------------------------------
# React SPA fallback — serve index.html for all other routes
# ------------------------------------------------------------------
RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]
